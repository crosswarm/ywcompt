    { "ruleName": "比价完整性", "trigger": "金额超比价阈值", "checkpoint": "≥3 家供应商比价，缺比价为风险", "severityHint": "warning" },
    { "ruleName": "预算匹配", "trigger": "总是", "checkpoint": "在已批采购计划/预算内，未超月度计划", "severityHint": "warning" },
    { "ruleName": "供应商资质", "trigger": "新供应商", "checkpoint": "营业执照/资质有效，无历史违约", "severityHint": "warning" }
  ],
  "keyFields": ["合同金额", "金额合计", "付款条件", "预付比例", "供应商", "申请部门", "预算科目"],
