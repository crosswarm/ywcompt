{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "approve-inbox.schema.json",
  "title": "审批收件箱组件数据契约",
  "description": "外部组件 approve-inbox 的 widget.data 数据结构（草案）。列表项 + 详情 5 段。详见 docs/spec/approve-inbox-component.md",
  "type": "object",
  "required": ["businessType", "items"],
  "additionalProperties": true,
  "properties": {
    "businessType": { "type": "string", "const": "approve-inbox" },
    "summary": {
      "type": "object",
      "description": "顶部汇总（可选；codex 设计稿无大指标卡，前端可不渲染）",
      "additionalProperties": true,
      "properties": {
        "total": { "type": "integer" },
        "pendingCount": { "type": "integer" },
        "doneCount": { "type": "integer" },
        "lastSyncAt": { "type": "string", "description": "上次同步时间 ISO" }
      }
    },
    "viewSettings": {
      "type": "object",
      "description": "视图默认设置",
      "additionalProperties": true,
      "properties": {
        "defaultTabId": { "type": "string", "description": "默认页签，如 all-todo" },
        "defaultSort": { "type": "string", "enum": ["received-asc", "received-desc", "submitted-asc", "submitted-desc", "importance-desc", "risk-desc", "advice-desc", "title-asc"] }
      }
    },
    "items": {
      "type": "array",
      "description": "审批列表项",
      "items": {
        "type": "object",
        "required": ["id", "title", "riskLevel"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "description": "单据/待办唯一 ID（primaryId）" },
          "taskId": { "type": ["string", "null"], "description": "审批任务 ID（智能审核查询用）" },
          "workflowBusinessKey": { "type": ["string", "null"], "description": "流程业务键（智能审核查询用；区别于单据详情业务键）" },
          "yhtUserId": { "type": ["string", "null"], "description": "友户通用户 ID（智能审核精确查询用；缺失时不传）" },
          "title": { "type": "string", "description": "单据标题" },
          "docType": { "type": "string", "description": "已废弃的兼容展示字段；新逻辑优先使用 serviceName" },
          "serviceCode": { "type": ["string", "null"], "description": "用于解析服务名称的标准服务编码" },
          "sourceServiceCode": { "type": ["string", "null"], "description": "待办来源提供的原始服务编码" },
          "serviceName": { "type": ["string", "null"], "description": "准确的服务/业务入口显示名称；不保证等同于具体单据名称" },
          "serviceNameSource": {
            "type": ["string", "null"],
            "description": "服务名称来源；正式元数据查询由 iuap-apcom-cli 技能提供",
            "enum": ["todo", "iuap-apcom-cli.auth.permission.apply", null]
          },
          "originalUrl": { "type": "string", "description": "原始单据详情页 URL；前端新标签打开" },
          "riskLevel": {
            "type": "string",
            "description": "风险等级；统一展示文案为 high=重要、medium=需关注、low=建议通过",
            "enum": ["high", "medium", "low"]
          },
          "status": { "type": "string", "enum": ["pending", "done"], "description": "待办/已办" },
          "submittedAt": { "type": "string", "description": "提交时间 ISO（默认升序）" },
          "receivedAt": { "type": ["string", "null"], "description": "最佳可得的任务到手时间 ISO；不得用提交或同步时间冒充" },
          "receivedAtSource": {
            "type": "string",
            "description": "到手时间原始来源，按 workflow task、消息中心创建、消息时间依次降级",
            "enum": ["workflow.task.createTime", "message-center.createTsLong", "message-center.createTime", "message-center.msgTsLong", "unavailable"]
          },
          "receivedAtSemantics": {
            "type": "string",
            "enum": ["task-created", "message-created", "message-timestamp", "unavailable"]
          },
          "receivedAtSourceLabel": { "type": "string", "description": "面向用户的时间来源及近似说明" },
          "dueAt": { "type": ["string", "null"], "description": "截止时间 ISO（可选；驾驶舱 widget 逾期统计优先使用）" },
          "submitter": { "type": "string", "description": "提交人姓名（真实数据由 commitUserName 映射；前端在列表 meta 行展示）" },
          "advice": {
            "type": "string",
            "description": "AI 审批结论三态（来自 [ADVICE:*]）",
            "enum": ["approve", "caution", "reject"]
          },
          "aiSuggestion": {
            "type": "string",
            "description": "列表展示用 AI 建议，优先来自总体分析，其次来自最高优先级审核规则"
          },
          "smartTags": {
            "type": "array",
            "description": "智能标识（去前缀，直接值；前端最多显示 3 个，超出 +N）",
            "items": {
              "type": "object",
              "required": ["label"],
              "additionalProperties": true,
              "properties": {
                "label": { "type": "string", "description": "标签文本，如 高金额（不带『风险项：』前缀）" },
                "kind": { "type": "string", "enum": ["risk", "rule", "advice"], "description": "类别（可影响颜色）" }
              }
            }
          },
          "runtimeActions": {
            "type": "array",
            "description": "当前应用具备执行策略的行操作按钮；真实执行前仍必须刷新工作流动作",
            "items": {
              "type": "object",
              "required": ["action"],
              "additionalProperties": true,
              "properties": {
                "action": { "type": "string", "description": "approve/reject/transfer 等" },
                "label": { "type": "string" },
                "kind": { "type": "string", "description": "动作类型，如 workflow/business/navigation" },
                "execType": { "type": "string", "description": "真实回调执行类型（来自 skill）" },
                "callBackExecType": { "type": "string", "description": "YonBIP 待办按钮回调类型，如 agree/reject" },
                "enabled": { "type": "boolean" },
                "source": { "type": "string", "description": "动作来源，如 todo.buttons / handler.refreshActions / legacy.compat" },
                "observedAt": { "type": "string", "description": "动作快照观察或刷新时间 ISO" },
                "requiresRefresh": { "type": "boolean", "description": "执行前是否必须刷新动作" },
                "endpointHint": { "type": "string", "description": "执行端点提示，仅用于分发和诊断" },
                "buttonIndex": { "type": "number", "description": "原始按钮顺序" }
              }
            }
          },
          "observedActions": {
            "type": "array",
            "description": "消息中心上次返回的原始动作快照，仅用于能力判断与诊断，不代表当前可执行",
            "items": {
              "type": "object",
              "required": ["action"],
              "additionalProperties": true
            }
          }
        }
      }
    },
    "detail": {
      "type": "object",
      "description": "单据详情（5 段结构，按需异步加载）",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "businessKey": { "type": ["string", "null"], "description": "单据业务键，通常为 billnum_billId；URL query busiObj 非空时为 busiObj_billId" },
        "title": { "type": "string" },
        "originalUrl": { "type": "string", "description": "原始单据详情页 URL；前端新标签打开" },
        "conclusion": {
          "type": "object",
          "description": "① 总体结论（通过/不通过）",
          "required": ["advice"],
          "additionalProperties": true,
          "properties": {
            "advice": { "type": "string", "enum": ["approve", "caution", "reject"] },
            "label": { "type": "string", "description": "如 建议通过/需关注/建议拒绝" }
          }
        },
        "compositeAdvice": {
          "type": ["object", "null"],
          "description": "综合审批建议：系统预置规则优先，用户级规则补充",
          "additionalProperties": true,
          "properties": {
            "advice": { "type": "string", "enum": ["approve", "caution", "reject"] },
            "label": { "type": "string" },
            "riskLevel": { "type": "string", "enum": ["high", "medium", "low"] },
            "source": { "type": "string", "description": "system / user / fallback" },
            "summary": { "type": "string" },
            "reasons": { "type": "array", "items": { "type": "string" } },
            "conflict": { "type": "boolean" },
            "systemAdvice": { "type": ["string", "null"], "enum": ["approve", "caution", "reject", null] },
            "userAdvice": { "type": ["string", "null"], "enum": ["approve", "caution", "reject", null] },
            "fetchedAt": { "type": ["string", "null"] }
          }
        },
        "systemRuleAudit": {
          "type": ["object", "null"],
          "description": "系统预置规则：智能审核 API 实时结果",
          "additionalProperties": true,
          "properties": {
            "status": { "type": "string", "description": "success / not_found / disabled / model_error / error / skipped" },
            "code": { "type": ["integer", "string", "null"] },
            "message": { "type": "string" },
            "displayCode": { "type": "string" },
            "detailMsg": { "type": "string" },
            "level": { "type": "number" },
            "resultId": { "type": "string" },
            "queryId": { "type": "string" },
            "resultDesc": { "type": "string" },
            "AISummaryResultDesc": { "type": "string" },
            "fetchedAt": { "type": "string" },
            "reason": { "type": "string" },
            "httpStatus": { "type": "number" }
          }
        },
        "overallAnalysis": { "type": "string", "description": "② 总体分析（~40 字简述）" },
        "fieldAnalysis": {
          "type": "array",
          "description": "③ 单据字段分析（多条）",
          "items": {
            "type": "object",
            "required": ["name", "summary"],
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "description": "字段/检查点名称" },
              "value": { "type": "string", "description": "字段值（可选）" },
              "summary": { "type": "string", "description": "分析结论" },
              "severity": { "type": "string", "enum": ["risk", "warning", "passed"] }
            }
          }
        },
        "ruleAnalysis": {
          "type": "array",
          "description": "④ 业务规则分析（多条，Agent 自主发现，每条带依据）",
          "items": {
            "type": "object",
            "required": ["ruleName", "severity", "summary"],
            "additionalProperties": true,
            "properties": {
              "ruleName": { "type": "string" },
              "severity": { "type": "string", "enum": ["risk", "warning", "passed"] },
              "summary": { "type": "string", "description": "规则结论" },
              "evidence": { "type": "string", "description": "命中依据（Agent 须给出）" },
              "suggestion": { "type": "string" }
            }
          }
        },
        "attachmentAnalysis": {
          "type": "array",
          "description": "⑤ 附件分析",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "description": "附件名" },
              "fileType": { "type": "string" },
              "severity": { "type": "string", "enum": ["risk", "warning", "passed"] },
              "summary": { "type": "string", "description": "附件审核结论" },
              "findings": {
                "type": "array",
                "description": "附件级发现项",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "name": { "type": "string" },
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "fields": {
          "type": "array",
          "description": "真实抓取的单据字段，展示在详情顶部",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "additionalProperties": true,
            "properties": {
              "key": { "type": "string", "description": "原始字段 key" },
              "name": { "type": "string", "description": "可读字段名，优先中文" },
              "value": { "type": "string", "description": "可读字段值" },
              "dim": { "type": "string", "description": "关联审核维度" }
            }
          }
        },
        "richDetail": {
          "type": "object",
          "description": "稳定详情富模型：raw + meta + normalized。展示、搜索和 AI prompt 应优先读取 normalized.fields。",
          "additionalProperties": true,
          "properties": {
            "schemaVersion": { "type": "integer" },
            "primaryId": { "type": "string" },
            "businessKey": { "type": "string", "description": "单据业务键，通常为 billnum_billId；URL query busiObj 非空时为 busiObj_billId" },
            "framework": { "type": "string", "description": "mdf / iform / ynf / unknown" },
            "handlerId": { "type": "string" },
            "handlerSource": { "type": "string" },
            "fetchedAt": { "type": "string" },
            "raw": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "kind": { "type": "string" },
                "dataPath": { "type": "string" },
                "source": { "type": "string" }
              }
            },
            "meta": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "businessKey": { "type": "string", "description": "单据业务键，通常为 billnum_billId；URL query busiObj 非空时为 busiObj_billId" },
                "templateId": { "type": "string" },
                "templateName": { "type": "string" },
                "billNo": { "type": "string" },
                "fields": {
                  "type": "object",
                  "description": "fieldId -> 轻量字段元数据索引",
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "label": { "type": "string" },
                      "controlType": { "type": "string" },
                      "dataType": { "type": "string" },
                      "section": { "type": "string" },
                      "required": { "type": "boolean" },
                      "visible": { "type": "boolean" },
                      "editable": { "type": "boolean" },
                      "enumType": { "type": "string" },
                      "refCode": { "type": "string" },
                      "refType": { "type": "string" },
                      "options": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["value", "label"],
                          "additionalProperties": true,
                          "properties": {
                            "value": { "type": "string" },
                            "label": { "type": "string" }
                          }
                        }
                      }
                    }
                  }
                },
                "enums": { "type": "object", "additionalProperties": true },
                "references": { "type": "object", "additionalProperties": true },
                "sections": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label", "fieldIds"],
                    "additionalProperties": true
                  }
                }
              }
            },
            "normalized": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "fieldId": { "type": "string" },
                      "rawPath": { "type": "string" },
                      "label": { "type": "string" },
                      "rawValue": {},
                      "displayValue": { "type": "string" },
                      "section": { "type": "string" },
                      "visible": { "type": "boolean" },
                      "editable": { "type": "boolean" }
                    }
                  }
                },
                "byId": { "type": "object", "additionalProperties": true },
                "sections": { "type": "array" }
              }
            },
            "fieldLabels": { "type": "object", "additionalProperties": { "type": "string" } },
            "observedActions": {
              "type": "array",
              "description": "随详情保存的上次动作快照；真实执行仍需 refreshActions",
              "items": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "analyzed": { "type": "boolean", "description": "是否已完成真实 AI 分析" },
        "crossTenant": { "type": "boolean", "description": "当前登录态是否无权读取该租户字段" },
        "tenantName": { "type": ["string", "null"], "description": "跨租户名称" },
        "unavailableReason": { "type": ["string", "null"], "description": "真实字段不可用原因" },
        "analysisError": { "type": ["string", "null"], "description": "分析失败原因" },
        "source": { "type": "string", "enum": ["skill", "fallback"], "description": "数据来源：skill 真实分析 / 前端兜底" }
      }
    },
    "reviewSummary": {
      "type": "object",
      "description": "已办智能总结（以审核数据统计 + 分析为主；前端在已办 tab 渲染。真实数据无此字段时由 normalize.computeReviewSummary 现算）",
      "additionalProperties": true,
      "properties": {
        "period": { "type": "string", "description": "统计周期，如 近 7 天 / 已办汇总" },
        "total": { "type": "integer", "description": "已处理总数" },
        "approvedCount": { "type": "integer" },
        "rejectedCount": { "type": "integer" },
        "returnedCount": { "type": "integer" },
        "riskDistribution": {
          "type": "object",
          "description": "风险分布",
          "additionalProperties": true,
          "properties": {
            "high": { "type": "integer" },
            "medium": { "type": "integer" },
            "low": { "type": "integer" }
          }
        },
        "typeDistribution": {
          "type": "array",
          "description": "单据类型分布",
          "items": {
            "type": "object",
            "required": ["type", "count"],
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "highlights": {
          "type": "array",
          "description": "关键指标（通过率、平均处理时长等）",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": true,
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "analysis": { "type": "string", "description": "总体分析文字（数据统计结论）" }
      }
    }
  }
}
